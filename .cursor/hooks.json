{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-detect-stack.sh"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/log-task-start.sh"
      },
      {
        "command": ".cursor/hooks/route-work.sh",
        "matcher": ".*"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/log-task-end.sh"
      }
    ]
  }
}
